SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
OPENAI_API_KEY=your_openai_api_key
PORT=3001
FRONTEND_URL=http://localhost:5173

# Monitoring (optional)
SENTRY_DSN=https://your_key@sentry.io/your_project

# Email (optional — welcome emails via Resend)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Laktic <onboarding@laktic.app>

# Strava OAuth (optional — needed for activity sync)
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:3001/api/strava/callback
STRAVA_WEBHOOK_VERIFY_TOKEN=your_random_verify_token
